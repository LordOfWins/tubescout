# 환경변수 템플릿
# ── TubeScout Server Environment Variables ──

# App
APP_NAME=TubeScout API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=local

# CORS (쉼표로 구분하지 않음 — JSON 배열 형태)
# Chrome 확장 배포 후 실제 ID로 교체 필요
CORS_ORIGINS=["chrome-extension://your-extension-id-here","http://localhost:3000"]

# Lemon Squeezy
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
VARIANT_ID_FREE=0
VARIANT_ID_PRO=0
VARIANT_ID_ULTRA=0

# AI
GEMINI_API_KEY=
OPENAI_API_KEY=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.3

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Credits
CREDITS_FREE=20
CREDITS_PRO=500
CREDITS_ULTRA=2000
COST_ANALYZE_TITLE=1
COST_ANALYZE_CHANNEL=5
COST_SUGGEST_TAGS=3

# AI Model
AI_MODEL_FREE=gemini-2.5-flash
AI_MODEL_PRO=gemini-2.5-flash
AI_MODEL_ULTRA=gpt-4o
